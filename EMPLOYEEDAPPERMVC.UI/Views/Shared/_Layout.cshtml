<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dapper MVC Demo</title>
    <link rel="stylesheet"
          href="https://cdn3.devexpress.com/jslib/25.2.3/css/dx.light.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />


</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">Employee Dapper Mvc</a>
            <div class="collapse navbar-collapse">
                <div class="navbar-nav">
                    <a class="nav-link" href="/Home/Index">Home</a>
                    <a class="nav-link" href="/Employee/DisplayAll">Employee</a>
                    <a class="nav-link" href="/Service/DisplayAll">Service</a>
                    <a class="nav-link" href="/Service/AssignEmployee">EmployeeService</a>
                    <a class="nav-link" href="/TimeSelect/DisplayAll">TimeSlot</a>
                    <a class="nav-link" href="/ServiceBooking/DisplayAll">Appointment booking</a>
                    <a class="nav-link" href="/ServiceBooking/chart">summarychart</a>
                    <a class="nav-link" href="/ServiceBooking/Summary"> Dashboard Summary</a>
                    <a class="nav-link" href="/Service/About"> About</a>


                </div>
            </div>
        </div>
    </nav>

    <main role="main" class="container">
        @RenderBody()
    </main>


    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn3.devexpress.com/jslib/25.2.3/js/dx.all.js"></script>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html> 
@model EMPLOYEEDAPPERMVC.Data.Models.Domain.Employee?

<input type="hidden" id="employeeId" value="@(Model?.Id ?? 0)" />

<div id="Validationsummary"></div>

<div class="mb-2">
    <label class="form-label">Name</label>
    <div id="txtName" data-value="@(Model?.Name ?? "")"></div>
</div>

<div class="mb-2">
    <label class="form-label">Email</label>
    <div id="txtEmail" data-value="@(Model?.Email ?? "")"></div>
</div>

<div class="mb-2">
    <label class="form-label">Phone</label>
    <div id="txtPhone" data-value="@(Model?.Phone ?? "")"></div>
</div>

<div class="mb-2">
    <label class="form-label">Address</label>
    <div id="txtAddress" data-value="@(Model?.Address ?? "")"></div>
</div>

<div class="mt-3">
    <button id="btnSave" class="btn btn-success">Save</button>
</div>



@{
    ViewData["Title"] = "Service Booking";
}

<h3>Book a Service</h3>

<div class="card mb-3">
    <div class="card-body">
        <div class="mb-3">
            <label>Choose Service</label>
            <div id="selectService"></div>
        </div>
        <div class="mb-3">
            <label>Choose Date</label>
            <div id="selectDate"></div>
        </div>
        <div class="mb-3">
            <button id="btnSearchSlots" class="btn btn-success">Search Slots</button>
        </div>
    </div>
</div>

<div id="slotsSection" style="display:none;">
    <div class="card mb-3">
        <div class="card-body">
            <h5>Available Time Slots</h5>
            <div id="slotsContainer"></div>
        </div>
    </div>
</div>

<div id="popupBooking"></div>

@section Scripts {
    <script src="~/js/ServiceBooking.js"></script>
}

@{
    ViewData["Title"] = "About";
}

<!-- HERO SECTION -->
<section class="container-fluid py-5" style="background-color:#f8f9fa;">
    <div class="row align-items-center px-4 px-lg-5">

        <!-- TEXT -->
        <div class="col-12 col-md-6 mb-4 mb-md-0">
            <h1 class="fw-bold mb-4" style="font-size:2.8rem; color:#212529;">
                Service Booking Management System
            </h1>

            <p class="fs-5 lh-lg text-secondary">
                A modern web-based application designed to manage services, employees,
                and customer appointments in a clean and efficient way.
            </p>

            <p class="fs-5 lh-lg text-secondary">
                The system helps businesses reduce manual work, avoid scheduling conflicts,
                and provide a smooth booking experience.
            </p>
        </div>

        <!-- IMAGE -->
        <div class="col-12 col-md-6 text-center">
            <img src="/Content/images/service-booking.png"
                 alt="Service Booking System"
                 class="img-fluid rounded-3"
                 style="max-height:420px;" />
        </div>

    </div>
</section>

<!-- OVERVIEW SECTION -->
<section class="container py-5">
    <div class="row">

        <div class="col-12">
            <h2 class="fw-semibold mb-4" style="color:#343a40;">
                System Overview
            </h2>

            <p class="fs-5 lh-lg text-secondary">
                Administrators manage employees and services using structured data grids.
                Each service has a defined duration, and employees can be assigned to one
                or more services based on their skills.
            </p>

            <p class="fs-5 lh-lg text-secondary">
                Employee working hours define availability, allowing the system to
                automatically generate time slots during booking.
            </p>

            <p class="fs-5 lh-lg text-secondary">
                Customers select a service, choose a date, and book an available time slot.
                Once booked, the slot is unavailable for other customers on the same date.
            </p>
        </div>

    </div>
</section>

<!-- FEATURES SECTION -->
<section class="container pb-5">
    <div class="row">

        <div class="col-12">
            <h2 class="fw-semibold mb-4" style="color:#343a40;">
                Key Features
            </h2>

            <ul class="fs-5 lh-lg text-secondary">
                <li>Employee and service management with CRUD operations</li>
                <li>Employee-to-service assignment</li>
                <li>Automatic time slot generation</li>
                <li>Date-based booking system</li>
                <li>Double booking prevention</li>
                <li>Responsive and user-friendly interface</li>
            </ul>
        </div>

    </div>
</section>
